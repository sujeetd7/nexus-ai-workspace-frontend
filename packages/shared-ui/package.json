{
  "name": "@nexus/shared-ui",
  "version": "0.0.1",
  "dependencies": {
    "@nexus/shared-types": "workspace:*",
    "@tamagui/core": "2.4.6"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-native-web": "^0.21.0",
    "vitest": "^4.1.10"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts",
      "react-native": "./src/index.ts"
    },
    "./tamagui-config": {
      "types": "./src/tamagui/config.ts",
      "import": "./src/tamagui/config.ts",
      "default": "./src/tamagui/config.ts",
      "react-native": "./src/tamagui/config.ts"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./src/testing/index.ts",
      "default": "./src/testing/index.ts",
      "react-native": "./src/testing/index.ts"
    }
  },
  "main": "./src/index.ts",
  "peerDependencies": {
    "react": "^19.1.0",
    "react-native": "*",
    "react-native-web": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "react-native-web": {
      "optional": true
    }
  },
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "type": "module",
  "types": "./src/index.ts"
}
