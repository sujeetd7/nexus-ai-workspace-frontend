{
  "name": "@nexus/shared-ui",
  "version": "0.0.1",
  "dependencies": {
    "@tamagui/core": "2.4.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.17"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts",
      "react-native": "./src/index.ts"
    },
    "./tamagui-config": {
      "types": "./src/tamagui/config.ts",
      "import": "./src/tamagui/config.ts",
      "default": "./src/tamagui/config.ts",
      "react-native": "./src/tamagui/config.ts"
    }
  },
  "main": "./src/index.ts",
  "peerDependencies": {
    "react": "^19.1.0",
    "react-native": "*",
    "react-native-web": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "react-native-web": {
      "optional": true
    }
  },
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "lint": "eslint src",
    "test": "jest --passWithNoTests --config jest.config.cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "type": "module",
  "types": "./src/index.ts"
}
