{
  "name": "nexus-ai-workspace-frontend",
  "version": "1.0.0",
  "commitlint": {
    "extends": [
      "./configs/commitlint/commitlint.config.cjs"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.1",
    "@commitlint/config-conventional": "19.8.1",
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "commander": "14.0.3",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "lint-staged": "16.1.6",
    "msw": "^2.15.0",
    "prettier": "2.8.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-test-renderer": "19.2.3",
    "rimraf": "^6.1.3",
    "syncpack": "13.0.4",
    "tsx": "^4.23.1",
    "turbo": "^2.5.6",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "engines": {
    "node": "22.22.2",
    "pnpm": "9.15.9"
  },
  "packageManager": "pnpm@9.15.9",
  "private": true,
  "scripts": {
    "adr:check": "node scripts/check-adr-ids.mjs",
    "android": "pnpm --filter mobile android",
    "boundaries:check": "node scripts/check-import-boundaries.mjs",
    "build": "turbo run build",
    "build:web": "pnpm --filter web build",
    "clean": "turbo run clean",
    "deps:check": "syncpack lint",
    "deps:fix": "syncpack fix-mismatches",
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter web dev",
    "gen": "tsx scripts/generators/cli.ts",
    "gen:api": "tsx scripts/generators/cli.ts api",
    "gen:component": "tsx scripts/generators/cli.ts component",
    "gen:feature": "tsx scripts/generators/cli.ts feature",
    "gen:graphql": "tsx scripts/generators/cli.ts graphql",
    "gen:hook": "tsx scripts/generators/cli.ts hook",
    "gen:saga": "tsx scripts/generators/cli.ts saga",
    "gen:screen": "tsx scripts/generators/cli.ts screen",
    "gen:slice": "tsx scripts/generators/cli.ts slice",
    "install:all": "pnpm install",
    "ios": "pnpm --filter mobile ios",
    "lint": "turbo run lint",
    "lint-staged": "lint-staged --config configs/lint-staged/lint-staged.config.cjs",
    "lint:web": "pnpm --filter web lint",
    "prepare": "husky",
    "start:mobile": "pnpm --filter mobile start",
    "storybook": "pnpm --filter web storybook",
    "storybook:build": "pnpm --filter web build-storybook",
    "test": "turbo run test && pnpm test:generators",
    "test:generators": "node --import tsx --test scripts/generators/__tests__/naming.test.ts scripts/generators/__tests__/engine.test.ts scripts/generators/__tests__/security.test.ts",
    "test:mobile": "pnpm --filter mobile test",
    "typecheck": "turbo run typecheck",
    "verify": "pnpm lint && pnpm typecheck && pnpm boundaries:check && pnpm adr:check && pnpm test && pnpm build && pnpm storybook:build"
  }
}
