{
  "name": "nexus-ai-workspace-frontend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.19.0",
    "pnpm": ">=9.15.9"
  },
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "lint:web": "pnpm --filter web lint",
    "start:mobile": "pnpm --filter mobile start",
    "android": "pnpm --filter mobile android",
    "ios": "pnpm --filter mobile ios",
    "test:mobile": "pnpm --filter mobile test",
    "install:all": "pnpm install",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "dev": "turbo run dev --parallel",
    "prepare": "husky",
    "lint-staged": "lint-staged --config configs/lint-staged/lint-staged.config.cjs",
    "gen": "tsx scripts/generators/cli.ts",
    "gen:component": "tsx scripts/generators/cli.ts component",
    "gen:screen": "tsx scripts/generators/cli.ts screen",
    "gen:feature": "tsx scripts/generators/cli.ts feature",
    "gen:hook": "tsx scripts/generators/cli.ts hook",
    "gen:slice": "tsx scripts/generators/cli.ts slice",
    "gen:saga": "tsx scripts/generators/cli.ts saga",
    "gen:api": "tsx scripts/generators/cli.ts api",
    "gen:graphql": "tsx scripts/generators/cli.ts graphql"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "commander": "^15.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest-environment-jsdom": "29.7.0",
    "lint-staged": "^17.0.8",
    "msw": "^2.15.0",
    "prettier": "2.8.8",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-test-renderer": "19.2.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.23.1",
    "turbo": "^2.5.6",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.64.0"
  },
  "commitlint": {
    "extends": [
      "./configs/commitlint/commitlint.config.cjs"
    ]
  }
}
