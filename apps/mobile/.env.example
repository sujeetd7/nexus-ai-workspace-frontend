# React Native public configuration (REFERENCE ONLY)
#
# This repository does not inject these values into the native app automatically.
# There is no approved react-native-config (or similar) integration yet.
#
# Current source of truth for mobile public config:
#   apps/mobile/src/config/publicConfig.ts
#
# Documented public fields (non-secret only):
#   buildMode=development|test|production
#   apiBaseUrl=http://localhost:3000/api
#   graphqlUrl=http://localhost:3000/graphql
#   appName=Nexus AI Workspace
#
# Do not place secrets, private API keys, or credentials here or in the typed source.
